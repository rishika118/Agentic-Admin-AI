# ==============================================================================
# .gitignore — Files & folders to NEVER commit to Git
# ==============================================================================

# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ---- Virtual Environment ----
venv/
.venv/
env/
.env/

# ---- Environment Variables (SENSITIVE — never commit!) ----
.env
backend/.env

# ---- Node / npm ----
node_modules/
frontend/node_modules/
npm-debug.log*

# ---- Vite Build Output ----
frontend/dist/

# ---- Uploaded Files (can be large) ----
storage/uploads/*
!storage/uploads/.gitkeep
storage/pdfs/*
!storage/pdfs/.gitkeep

# ---- IDE / OS ----
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ---- Python Coverage & Testing ----
.coverage
htmlcov/
.pytest_cache/
