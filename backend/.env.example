# ==============================================================================
# .env.example — Environment Variable Template
# ==============================================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env to Git (it's in .gitignore)
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_NAME="Agentic Admin AI"
APP_VERSION="1.0.0"
ENVIRONMENT=development          # development | production
DEBUG=True

# ------------------------------------------------------------------------------
# CORS — React dev server URL (update if you change the port)
# ------------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentic_admin
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# ------------------------------------------------------------------------------
# Qdrant (Vector Database)
# Qdrant runs locally on port 6333 by default.
# Download: https://qdrant.tech/documentation/quick-start/
# ------------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=admin_documents

# ------------------------------------------------------------------------------
# Ollama (Local LLM)
# Install: https://ollama.com/
# Pull model: ollama pull mistral
# ------------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:latest

# ------------------------------------------------------------------------------
# Embeddings
# The model is downloaded automatically by sentence-transformers on first run.
# EMBEDDING_DIMENSION must match the chosen model's output size.
# bge-small-en-v1.5 → 384 dimensions
# ------------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# ------------------------------------------------------------------------------
# File Storage
# Documents uploaded via the UI are saved here.
# ------------------------------------------------------------------------------
UPLOAD_FOLDER=./storage/uploads
MAX_UPLOAD_SIZE_MB=50

# ------------------------------------------------------------------------------
# Text Chunking
# CHUNK_SIZE    = characters per chunk
# CHUNK_OVERLAP = characters shared between consecutive chunks
# ------------------------------------------------------------------------------
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ------------------------------------------------------------------------------
# Future / Reserved — uncomment when needed
# ------------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
